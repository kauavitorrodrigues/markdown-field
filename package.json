{
  "name": "@kauavitorrodrigues/markdown-field",
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "description": "A markdown editor and viewer field for React, built on Tiptap.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kauavitorrodrigues/markdown-field.git"
  },
  "homepage": "https://github.com/kauavitorrodrigues/markdown-field#readme",
  "bugs": {
    "url": "https://github.com/kauavitorrodrigues/markdown-field/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./typeset.css": "./dist/typeset.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && rm -f dist/_styles.js dist/_styles.js.map dist/_styles.d.ts && mv -f dist/_styles.css dist/typeset.css",
    "prepublishOnly": "pnpm build:lib",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4"
  },
  "dependencies": {
    "@floating-ui/dom": "1.7.6",
    "@tiptap/core": "3.28.0",
    "@tiptap/extension-bubble-menu": "3.28.0",
    "@tiptap/extension-image": "3.28.0",
    "@tiptap/extension-link": "3.28.0",
    "@tiptap/extension-placeholder": "3.28.0",
    "@tiptap/extension-strike": "3.28.0",
    "@tiptap/extension-table": "3.28.0",
    "@tiptap/extension-table-cell": "3.28.0",
    "@tiptap/extension-table-header": "3.28.0",
    "@tiptap/extension-table-row": "3.28.0",
    "@tiptap/pm": "3.28.0",
    "@tiptap/react": "3.28.0",
    "@tiptap/starter-kit": "3.28.0",
    "@tiptap/suggestion": "3.28.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.17.0",
    "motion": "12.40.0",
    "radix-ui": "1.5.0",
    "tailwind-merge": "3.6.0",
    "tiptap-markdown": "0.9.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@fontsource-variable/inter": "5.2.8",
    "@microsoft/api-extractor": "^7.58.12",
    "@tailwindcss/vite": "4.3.0",
    "@types/mdast": "4.0.4",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "4.11.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vite-plugin-dts": "5.0.3"
  }
}
